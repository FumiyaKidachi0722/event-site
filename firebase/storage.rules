rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /events/{eventId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
